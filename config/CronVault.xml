<service>
  <id>CronVault</id>
  <name>CronVault</name>
  <description>CronVault scheduler service</description>
  <executable>cronvault.exe</executable>
  <arguments>--service</arguments>
  <logpath>logs</logpath>
  <log mode="roll" />
  <onfailure action="restart" delay="5000" />
  <startmode>Automatic</startmode>
</service>
